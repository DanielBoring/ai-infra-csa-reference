# ---------------------------------------------------------------------------
# Environment Variables for the Chatbot App
# Copy to .env and fill in values. NEVER commit .env to git.
# ---------------------------------------------------------------------------

# APIM gateway URL (set after deploying infrastructure)
APIM_ENDPOINT=https://apim-ai-infra-ref-dev.azure-api.net

# APIM subscription key (set after creating an APIM subscription)
APIM_SUBSCRIPTION_KEY=

# Managed Identity client ID (set after deploying infrastructure)
# Used for Azure SDK DefaultAzureCredential in production
AZURE_CLIENT_ID=

# Application Insights connection string (set after deploying infrastructure)
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Server port
PORT=3000

# Node environment
NODE_ENV=development
